---
import '../styles/toc.css'
---

<div id="toc"></div>

<script>
  ;(() => {
  let updateTocActive: (() => void) | null = null
  let headings: HTMLElement[] = []

  function buildToc() {
    const tocContainer = document.getElementById('toc')
    if (!tocContainer) return

    headings = Array.from(document.querySelectorAll('main h2, main h3, main h4, main h5')).filter(
      (h): h is HTMLElement => h instanceof HTMLElement && h.id.length > 0,
    )

    if (headings.length === 0) {
      tocContainer.innerHTML = ''
      tocContainer.removeAttribute('data-ready')
      updateTocActive = null
      return
    }

    tocContainer.innerHTML = headings
      .map((h) => `<span class="toc-${h.tagName}"><a href="#${h.id}" data-id="${h.id}">${h.innerText}</a></span>`)
      .join('')
    tocContainer.setAttribute('data-ready', 'true')
    tocContainer.querySelectorAll<HTMLAnchorElement>('a').forEach((link) => {
      link.addEventListener('click', (event) => {
        event.preventDefault()
        const id = link.dataset.id
        if (!id) return
        document.getElementById(id)?.scrollIntoView({ behavior: 'smooth', block: 'start' })
        history.replaceState(null, '', `#${id}`)
        setActive(id)
      })
    })

    function setActive(id: string) {
      tocContainer.querySelectorAll('a').forEach((a) => a.classList.remove('active'))
      tocContainer.querySelector<HTMLAnchorElement>(`a[data-id="${CSS.escape(id)}"]`)?.classList.add('active')
    }

    updateTocActive = () => {
      const threshold = Math.min(window.innerHeight * 0.28, 220)
      let current = headings[0]
      for (const h of headings) {
        if (h.getBoundingClientRect().top < threshold) {
          current = h
        }
      }
      setActive(current.id)
    }

    updateTocActive()
  }

  if (!(window as any).__tocReady) {
    ;(window as any).__tocReady = true
    window.addEventListener('scroll', () => updateTocActive?.(), { passive: true })
    window.addEventListener('resize', () => updateTocActive?.())
    document.addEventListener('DOMContentLoaded', buildToc)
    document.addEventListener('astro:page-load', buildToc)
  }

  buildToc()
  })()
</script>
