---
import sentenceJson from '../data/sentence.json'

const sentences = sentenceJson.flatMap((item) => item.li_texts)
---

<button id="sentence" type="button" title="换一句"></button>

<style>
  #sentence {
    display: block;
    width: 100%;
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    line-height: 1.8;
    text-align: left;
    cursor: pointer;
  }

  #sentence:hover,
  #sentence:focus-visible {
    color: var(--accent);
  }

  #sentence.switching {
    animation: sentence-fade 220ms ease-out;
  }

  @keyframes sentence-fade {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #sentence.switching {
      animation: none;
    }
  }
</style>

<script is:inline define:vars={{ sentences }}>
  const el = document.getElementById('sentence')
  const storageKey = 'storedIndex'

  function readIndex() {
    const stored = Number.parseInt(localStorage.getItem(storageKey), 10)
    return Number.isFinite(stored) ? stored : 0
  }

  function renderSentence(index, animate = false) {
    if (!el) return
    el.textContent = sentences[index]
    if (!animate) return
    el.classList.remove('switching')
    void el.offsetWidth
    el.classList.add('switching')
  }

  function nextSentence(animate = false) {
    const index = readIndex() % sentences.length
    renderSentence(index, animate)
    localStorage.setItem(storageKey, String((index + 1) % sentences.length))
  }

  nextSentence(false)
  el?.addEventListener('click', () => nextSentence(true))
</script>
