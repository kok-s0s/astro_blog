---
import sentenceJson from '../data/sentence.json'
import sentenceEnJson from '../data/sentence-en.json'

const basePath = (import.meta.env.BASE_URL || '/').replace(/\/$/, '')
const currentPath = basePath && basePath !== '/' && Astro.url.pathname.startsWith(basePath)
  ? Astro.url.pathname.slice(basePath.length) || '/'
  : Astro.url.pathname
const isEnglish = currentPath === '/en' || currentPath.startsWith('/en/')
const sentences = (isEnglish ? sentenceEnJson : sentenceJson).flatMap((item) => item.li_texts)
const storageKey = isEnglish ? 'storedIndex:en' : 'storedIndex:zh'
const title = isEnglish ? 'Another sentence' : '换一句'
---

<button id="sentence" type="button" title={title} aria-label={title} data-sentences={JSON.stringify(sentences)} data-storage-key={storageKey}></button>

<style>
  #sentence {
    display: block;
    width: 100%;
    border: 0;
    padding: 0;
    background: transparent;
    color: var(--text);
    font: inherit;
    line-height: 1.8;
    text-align: left;
    cursor: pointer;
  }

  #sentence:hover,
  #sentence:focus-visible {
    color: var(--accent);
  }

  #sentence.switching {
    animation: sentence-fade 220ms ease-out;
  }

  @keyframes sentence-fade {
    from {
      opacity: 0;
      transform: translateY(3px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #sentence.switching {
      animation: none;
    }
  }
</style>

<script is:inline>
  ;(() => {
    function getState(el) {
      const list = JSON.parse(el.dataset.sentences || '[]')
      const storageKey = el.dataset.storageKey || 'storedIndex:zh'
      return { list, storageKey }
    }

    function readIndex(storageKey) {
      const stored = Number.parseInt(localStorage.getItem(storageKey), 10)
      return Number.isFinite(stored) ? stored : 0
    }

    function renderSentence(el, index, animate = false) {
      const { list } = getState(el)
      if (!el || list.length === 0) return
      el.textContent = list[index % list.length]
      if (!animate) return
      el.classList.remove('switching')
      void el.offsetWidth
      el.classList.add('switching')
    }

    function nextSentence(el, animate = false) {
      const { list, storageKey } = getState(el)
      if (!el || list.length === 0) return
      const index = readIndex(storageKey) % list.length
      renderSentence(el, index, animate)
      localStorage.setItem(storageKey, String((index + 1) % list.length))
    }

    function initSentence() {
      const el = document.getElementById('sentence')
      if (!el) return
      nextSentence(el, false)
      if (el.dataset.ready === 'true') return
      el.dataset.ready = 'true'
      el.addEventListener('click', () => nextSentence(el, true))
    }

    window.__initSentence = initSentence

    if (!window.__sentenceReady) {
      window.__sentenceReady = true
      document.addEventListener('astro:page-load', initSentence)
    }

    initSentence()
  })()
</script>
