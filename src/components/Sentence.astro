---
import sentenceJson from '../data/sentence.json'

const sentences = sentenceJson.flatMap((item) => item.li_texts)
---

<p id="sentence"></p>

<script is:inline define:vars={{ sentences }}>
  const storedIndex = parseInt(localStorage.getItem('storedIndex')) || 0
  const el = document.getElementById('sentence')
  if (el) el.textContent = sentences[storedIndex]
  localStorage.setItem('storedIndex', String((storedIndex + 1) % sentences.length))
</script>
