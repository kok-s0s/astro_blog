---
import Hamburger from './Hamburger.astro'
import Navigation from './Navigation.astro'
import ThemeToggle from './ThemeToggle.astro'
import LanguageToggle from './LanguageToggle.astro'
import { withBase } from '../utils/path'
import { localizedPath } from '../utils/i18n'

const { lang = 'zh' } = Astro.props
---

<header>
  <nav id="header">
    <Hamburger lang={lang} />
    <Navigation lang={lang} />
    <div id="header-actions">
      <LanguageToggle />
      <ThemeToggle lang={lang} />
      <a href={withBase(localizedPath('/search', lang))} class="icon-btn" aria-label={lang === 'en' ? 'Search' : 'жРЬзіҐ'} title={lang === 'en' ? 'Search (Ctrl+K)' : 'жРЬзіҐ (Ctrl+K)'}>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="6.5" cy="6.5" r="4"/>
          <line x1="10" y1="10" x2="14" y2="14"/>
        </svg>
      </a>
      <a href={withBase('/rss.xml')} class="icon-btn" aria-label={lang === 'en' ? 'RSS feed' : 'RSS иЃҐйШЕ'} title={lang === 'en' ? 'RSS feed' : 'RSS иЃҐйШЕ'}>
        <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor">
          <circle cx="3" cy="13" r="1.8"/>
          <path d="M2 8.5a6.5 6.5 0 0 1 6.5 6.5H10A7.5 7.5 0 0 0 2 7v1.5z"/>
          <path d="M2 4.5a10.5 10.5 0 0 1 10.5 10.5H14A12 12 0 0 0 2 3v1.5z"/>
        </svg>
      </a>
    </div>
  </nav>
</header>

<style>
  #header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0;
  }

  #header-actions {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    flex-shrink: 0;
  }

  .icon-btn {
    display: inline-grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border-radius: 6px;
    color: var(--muted);
    transition: color 0.18s ease, background 0.18s ease;
  }

  .icon-btn:link,
  .icon-btn:visited {
    color: var(--muted);
  }

  .icon-btn:hover,
  .icon-btn:focus-visible {
    background: var(--code-bg);
    color: var(--accent);
  }

  .icon-btn svg {
    display: block;
    width: 1.18rem;
    height: 1.18rem;
  }
</style>
