---
const { title, url, pubDate } = Astro.props
const date = new Date(pubDate)
const formattedPubDate = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`
---

<li>
  <a href={url}>
    <span class="title">{title}</span>
    <span class="time">{formattedPubDate}</span>
  </a>
</li>

<style>
  li {
    list-style: none;
    border-bottom: 1px solid var(--border);
    transition: border-color 0.2s;
  }

  li:last-child {
    border-bottom: none;
  }

  a {
    width: 100%;
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.55rem 0.6rem;
    border-radius: 6px;
    transform: translateX(0);
    transition: background 0.18s ease, transform 0.18s ease, opacity 0.18s ease;
  }

  a:link,
  a:visited {
    color: var(--accent);
  }

  a:hover,
  a:active {
    color: var(--accent);
    background: var(--code-bg);
    transform: translateX(4px);
    opacity: 1;
  }

  .title {
    flex: 1;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .time {
    flex-shrink: 0;
    font-family: ui-monospace, 'SF Mono', Menlo, Consolas, monospace;
    font-size: 0.82rem;
    color: var(--muted);
  }

  /* 移动端：日期换行到标题下方 */
  @media (max-width: 480px) {
    a {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.15rem;
      padding: 0.6rem 0.4rem;
    }

    .title {
      white-space: normal;
      overflow: visible;
      text-overflow: unset;
    }

    .time {
      font-size: 0.78rem;
    }
  }
</style>
