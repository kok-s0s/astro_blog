---
import { alternateLangPath } from '../utils/i18n'
import { withBase } from '../utils/path'

const isEnglish = Astro.url.pathname.replace(/\/$/, '').includes('/en')
const href = withBase(alternateLangPath(Astro.url.pathname))
const label = isEnglish ? 'ZH' : 'EN'
const title = isEnglish ? 'Switch to Chinese' : 'Switch to English'
---

<a href={href} class="lang-toggle" aria-label={title} title={title}>{label}</a>

<style>
  .lang-toggle {
    display: inline-grid;
    place-items: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border-radius: 6px;
    color: var(--muted);
    font-family: ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.03em;
    line-height: 1;
    transition: color 0.18s ease, background 0.18s ease;
  }

  .lang-toggle:link,
  .lang-toggle:visited {
    color: var(--muted);
  }

  .lang-toggle:hover,
  .lang-toggle:focus-visible {
    background: var(--code-bg);
    color: var(--accent);
  }
</style>
