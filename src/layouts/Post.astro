---
import Toc from '../components/Toc.astro'
import BaseLayout from './Base.astro'
import { withBase } from '../utils/path'

const { frontmatter, rawContent } = Astro.props

const content = rawContent ? rawContent() : ''
const chineseChars = (content.match(/[一-龥]/g) || []).length
const englishWords = (content.match(/\b[a-zA-Z]+\b/g) || []).length
const readingTime = Math.max(1, Math.ceil(chineseChars / 300 + englishWords / 200))

const projectPosts = Object.values(import.meta.glob('../pages/posts/*.md', { eager: true })) as any[]
projectPosts.sort((a, b) => (new Date(b.frontmatter.pubDate) as any) - (new Date(a.frontmatter.pubDate) as any))
let currentPostIndex = -1
projectPosts.forEach((post, index) => {
  if (post.frontmatter.title === frontmatter.title) {
    currentPostIndex = index
  }
})
const previousPost = projectPosts[(currentPostIndex - 1 + projectPosts.length) % projectPosts.length]
const nextPost = projectPosts[(currentPostIndex + 1) % projectPosts.length]
---

<BaseLayout pageTitle={frontmatter.title} description={frontmatter.description} ogImage={frontmatter.image?.url}>
  <p class="time">Publish by<b><em>{frontmatter.pubDate.slice(0, 10)}</em></b></p>
  <p class="time">Updated by<b><em>{frontmatter.updatedDate.slice(0, 10)}</em></b></p>
  <p class="time">Read in<b><em>~{readingTime} min</em></b></p>
  <p><em>{frontmatter.description}</em></p>
  <p>Written by - <b><em>{frontmatter.author}</em></b></p>
  <img src={withBase(frontmatter.image.url)} width="300" alt={frontmatter.image.alt} loading="lazy" decoding="async" />
  <div class="tags">
    {
      frontmatter.tags.map((tag) => (
        <p class="tag">
          <a href={withBase(`/tags/${tag}`)}>{tag}</a>
        </p>
      ))
    }
  </div>
  <Toc />
  <slot />
  {
    (() => {
      const related = projectPosts.filter(
        (p) =>
          p.frontmatter.title !== frontmatter.title &&
          p.frontmatter.tags?.some((t: string) => frontmatter.tags?.includes(t)),
      )
      if (related.length === 0) return null
      return (
        <div id="related-posts">
          <h3>相关文章</h3>
          <ul>
            {related.slice(0, 3).map((p: any) => (
              <li>
                <a href={p.url}>{p.frontmatter.title}</a>
              </li>
            ))}
          </ul>
        </div>
      )
    })()
  }
  <div id="previous-next-article">
    <a href={previousPost.url} id="previous" class="underline">{previousPost.frontmatter.title}</a>
    <a href={nextPost.url} id="next" class="underline">{nextPost.frontmatter.title}</a>
  </div>
</BaseLayout>

<style>
  img {
    margin-bottom: 0.5rem;
  }

  #related-posts ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #related-posts li {
    padding: 0.2rem 0;
  }
</style>
