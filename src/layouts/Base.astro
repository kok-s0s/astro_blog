---
import '../styles/global.css'
import 'katex/dist/katex.min.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
import Top from '../components/Top.astro'
import ProgressBar from '../components/ProgressBar.astro'
import Particles from '../components/Particles.astro'
import Bankai from '../components/Bankai.astro'
import GlobalMusicPlayer from '../components/GlobalMusicPlayer.astro'
import { withBase } from '../utils/path'
import { ClientRouter } from 'astro:transitions'

interface Props {
  pageTitle: string
  description?: string
  ogImage?: string
}

const { pageTitle, description = '关于 C++、Qt、工具链和软件开发的技术博客', ogImage = '/images/moon.jpeg' } = Astro.props
const canonicalURL = new URL(Astro.url.pathname, Astro.site)
const ogImageURL = new URL(withBase(ogImage), Astro.site)
---

<html lang="zh">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={withBase('/zero.jpeg')} />
    <link rel="stylesheet" href={withBase('/css/prism-nord.css')} />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- SEO -->
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:url" content={canonicalURL} />

    <!-- RSS -->
    <link rel="alternate" type="application/rss+xml" title="kok-s0s · 博客" href={withBase('/rss.xml')} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Noto+Serif+SC:wght@400;700&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/lxgw-wenkai-screen-webfont@1.1.0/style.css" rel="stylesheet" />

    <title>{pageTitle}</title>
    <ClientRouter />
    <slot name="head" />
    <!-- 防止主题切换闪烁 -->
    <script is:inline>
      ;(function () {
        const saved = localStorage.getItem('theme')
        const system = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark'
        if ((saved ?? system) === 'light') document.documentElement.classList.add('light')
      })()
    </script>
  </head>
  <body>
    <Particles />
    <Bankai />
    <ProgressBar />
    <Header />
    <main data-pagefind-body>
      <h1>{pageTitle}</h1>
      <slot />
    </main>
    <Footer />
    <Top />
    <GlobalMusicPlayer />
    <script>
      import '../scripts/copy.js'
      import '../scripts/zoom-images'

      if (!(window as any).__searchShortcutReady) {
        ;(window as any).__searchShortcutReady = true
        document.addEventListener('keydown', (e) => {
          if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
            e.preventDefault()
            const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`
            window.location.href = `${base}search`
          }
        })
      }
    </script>
    <script src="https://kit.fontawesome.com/094105c4c5.js" crossorigin="anonymous"></script>
  </body>
</html>
