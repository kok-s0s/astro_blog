---
import BaseLayout from '../../layouts/Base.astro'
import { withBase } from '../../utils/path'

const pageTitle = 'Search'
---

<BaseLayout pageTitle={pageTitle} lang="en" description="Search across the whole site.">
  <p class="tip">Full-text search across all indexed posts</p>
  <div id="search"></div>
</BaseLayout>

<link href={withBase('/pagefind/pagefind-ui.css')} rel="stylesheet" />
<script is:inline src={withBase('/pagefind/pagefind-ui.js')}></script>
<script is:inline>
  new PagefindUI({
    element: '#search',
    showSubResults: true,
    showImages: false,
    translations: {
      placeholder: 'Search...',
      zero_results: 'No results for "[SEARCH_TERM]"',
    },
  })
</script>

<style>
  .tip {
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #e8722a;
    --pagefind-ui-text: #c8b8a2;
    --pagefind-ui-background: #0e0b0a;
    --pagefind-ui-border: #3a2e26;
    --pagefind-ui-tag: #1c1612;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: 'LXGW WenKai Screen', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  html.light {
    --pagefind-ui-primary: #6c3fb5;
    --pagefind-ui-text: #3d2b5e;
    --pagefind-ui-background: #faf6ff;
    --pagefind-ui-border: #c5b8e0;
    --pagefind-ui-tag: #ede8f5;
  }
</style>
