---
import BaseLayout from '../layouts/Base.astro'

import { selfInfo, skills, repos, booksRead } from '../data/about'

const pageTitle = '关于'
---

<BaseLayout pageTitle={pageTitle}>

  <h2>个人</h2>
  <ul class="info-list">
    {selfInfo.map((info) => <li>{info}</li>)}
  </ul>

  <h2>能力</h2>
  <p class="section-tip">他认为程序员要熟练的<a href="#" id="normal" class="tip-link">能力</a>：</p>
  <ul class="skill-chips">
    {skills.map((skill) => <li>{skill}</li>)}
  </ul>

  <h2>项目</h2>
  <ul class="repo-list">
    {
      repos.map((repo) => (
        <li>
          <details>
            <summary>
              <a href={repo.link} target="_blank" rel="noopener" class="underline">
                {repo.name}
              </a>
            </summary>
            <p class="repo-desc">{repo.description}</p>
          </details>
        </li>
      ))
    }
  </ul>

  <details class="books-details">
    <summary>阅览过的书籍</summary>
    <ul class="book-list">
      {
        booksRead.map((book) => (
          <li class={book.status ? 'done' : 'pending'}>
            <span class="book-name">{book.status ? <s>{book.name}</s> : book.name}</span>
            <span class="book-desc">{book.description}</span>
          </li>
        ))
      }
    </ul>
  </details>

  <div id="passwordModal" class="modal">
    <div class="modal-content">
      <span class="close-button" id="closeButton">&times;</span>
      <p>请输入密码以查看内容：</p>
      <input type="password" id="passwordInput" placeholder="请输入密码" />
      <button id="submitPassword">提交</button>
    </div>
  </div>

</BaseLayout>

<style>
  /* ── 通用 section h2 ──────────────────────────────── */
  h2 {
    border-left: 3px solid var(--accent);
    padding-left: 0.6rem;
    margin-bottom: 0.5rem;
  }

  /* ── 个人信息列表 ─────────────────────────────────── */
  .info-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
  }

  .info-list li {
    padding: 0.55rem 0.6rem;
    border-bottom: 1px solid var(--border);
    color: var(--text);
    line-height: 1.7;
    border-radius: 5px;
    transition: background 0.15s;
  }

  .info-list li:last-child {
    border-bottom: none;
  }

  .info-list li:hover {
    background: var(--code-bg);
  }

  /* ── 能力提示文字 ─────────────────────────────────── */
  .section-tip {
    font-size: 0.88rem;
    color: var(--muted);
    margin: 0 0 0.6rem;
  }

  .tip-link {
    color: var(--accent) !important;
  }

  /* ── 技能 chip 标签 ───────────────────────────────── */
  .skill-chips {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-chips li {
    padding: 0.3rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-size: 0.88rem;
    color: var(--text);
    background: var(--tag-bg);
    transition: border-color 0.15s, color 0.15s;
  }

  .skill-chips li:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  /* ── 项目列表 ─────────────────────────────────────── */
  .repo-list {
    list-style: none;
    padding: 0;
    margin: 0 0 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .repo-list li {
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.15s;
  }

  .repo-list li:has(details[open]) {
    border-color: var(--accent);
  }

  .repo-list details {
    padding: 0 0.75rem;
  }

  .repo-list details[open] {
    padding-bottom: 0.75rem;
  }

  .repo-list summary {
    padding: 0.65rem 0;
    cursor: pointer;
    user-select: none;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .repo-list summary::marker,
  .repo-list summary::-webkit-details-marker {
    color: var(--accent);
    font-size: 0.7rem;
  }

  .repo-list summary a {
    color: var(--accent) !important;
  }

  .repo-desc {
    margin: 0;
    font-size: 0.9rem;
    color: var(--muted);
    line-height: 1.7;
  }

  /* ── 书籍列表 ─────────────────────────────────────── */
  .books-details {
    margin: 0 0 2rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0 0.75rem;
  }

  .books-details[open] {
    padding-bottom: 0.5rem;
  }

  .books-details > summary {
    padding: 0.65rem 0 0.65rem 0.25rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    user-select: none;
  }

  .books-details > summary::marker,
  .books-details > summary::-webkit-details-marker {
    color: var(--accent);
    font-size: 0.75rem;
  }

  .book-list {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0;
  }

  .book-list li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.45rem 0.4rem;
    border-bottom: 1px solid var(--border);
    border-radius: 5px;
    transition: background 0.15s;
  }

  .book-list li:last-child {
    border-bottom: none;
  }

  .book-list li:hover {
    background: var(--code-bg);
  }

  .book-name {
    flex: 1;
    min-width: 0;
    font-size: 0.9rem;
    color: var(--text);
  }

  .book-list li.done .book-name {
    color: var(--muted);
  }

  .book-desc {
    flex-shrink: 0;
    font-size: 0.78rem;
    color: var(--muted);
    white-space: nowrap;
  }

  @media (max-width: 480px) {
    .book-list li {
      flex-direction: column;
      gap: 0.1rem;
    }

    .book-desc {
      white-space: normal;
    }
  }

  /* ── 密码弹窗 ─────────────────────────────────────── */
  .modal {
    display: none;
    position: fixed;
    z-index: 1000;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(3px);
  }

  .modal-content {
    background: var(--toc-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    margin: 15% auto;
    padding: 1.5rem;
    width: min(300px, 90vw);
    text-align: center;
  }

  .close-button {
    color: var(--muted);
    float: right;
    font-size: 1.5rem;
    line-height: 1;
    cursor: pointer;
    transition: color 0.15s;
  }

  .close-button:hover {
    color: var(--heading);
  }

  #passwordInput {
    width: 100%;
    padding: 0.5rem 0.75rem;
    margin: 0.75rem 0;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    color: var(--text);
    font-size: 0.95rem;
    transition: border-color 0.2s;
    box-sizing: border-box;
  }

  #passwordInput:focus {
    border-color: var(--accent);
    outline: none;
  }

  #submitPassword {
    width: 100%;
    padding: 0.5rem;
    background: var(--accent);
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.15s;
  }

  #submitPassword:hover {
    background: var(--accent-hover);
  }
</style>

<script>
  const reposList = document.querySelector('.repo-list')
  if (reposList) {
    const detailsElements = reposList.getElementsByTagName('details')
    for (const details of detailsElements) {
      details.addEventListener('click', () => {
        for (const otherDetails of detailsElements) {
          if (otherDetails !== details) otherDetails.removeAttribute('open')
        }
      })
    }
  }

  const normalLink = document.getElementById('normal')
  const passwordModal = document.getElementById('passwordModal') as HTMLElement
  const closeButton = document.getElementById('closeButton')
  const submitPassword = document.getElementById('submitPassword')

  normalLink?.addEventListener('click', (event) => {
    event.preventDefault()
    passwordModal.style.display = 'block'
  })

  closeButton?.addEventListener('click', () => {
    passwordModal.style.display = 'none'
  })

  submitPassword?.addEventListener('click', () => {
    const correctPassword = 'kok-s0s'
    const inputPassword = (document.getElementById('passwordInput') as HTMLInputElement).value
    if (inputPassword === correctPassword) {
      window.location.href = '/roadmap'
    } else {
      alert('密码错误，请重试！')
    }
  })

  window.addEventListener('click', (event) => {
    if (event.target === passwordModal) passwordModal.style.display = 'none'
  })
</script>
