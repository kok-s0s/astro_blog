---
import BaseLayout from '../layouts/Base.astro'
import { withBase } from '../utils/path'

const pageTitle = '零'
---

<BaseLayout pageTitle={pageTitle}>
  <p>
    <em id="motto">『 無無無無_just4now 』</em>
  </p>
  <img src={withBase('/images/moon.jpeg')} alt="moon" id="moon" />
</BaseLayout>

<style>
  #motto {
    letter-spacing: 1.6px;
  }

  #moon {
    width: 50%;
  }
</style>
