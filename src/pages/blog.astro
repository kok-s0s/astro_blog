---
import BaseLayout from '../layouts/Base.astro'
import OriginalBlogPost from '../components/OriginalBlogPost.astro'
import BlogPost from '../components/BlogPost.astro'
import { withBase } from '../utils/path'

const projectPosts = Object.values(import.meta.glob('./posts/*.md', { eager: true })) as any[]
projectPosts.sort((a, b) => (new Date(b.frontmatter.updatedDate) as any) - (new Date(a.frontmatter.updatedDate) as any))
const cleanCxxPosts = Object.values(import.meta.glob('./posts/clean_cxx/*.md', { eager: true })) as any[]
const cxxCreationalPatternsPosts = Object.values(import.meta.glob('./posts/cxx_design_patterns/creational_patterns/*.md', { eager: true })) as any[]
const cxxStructuralPatternsPosts = Object.values(import.meta.glob('./posts/cxx_design_patterns/structural_patterns/*.md', { eager: true })) as any[]
const cxxBehavioralPatternsPosts = Object.values(import.meta.glob('./posts/cxx_design_patterns/behavioral_patterns/*.md', { eager: true })) as any[]
const pageTitle = '博文'
---

<BaseLayout pageTitle={pageTitle}>
  <blockquote>
    <p>记录所思，分享所得。</p>
  </blockquote>
  <nav class="blog-tools" aria-label="文章浏览方式">
    <a href={withBase('/blog')} class="active" aria-current="page">文章</a>
    <a href={withBase('/tags')}>标签</a>
    <a href={withBase('/archive')}>归档</a>
  </nav>
  <h2>原创</h2>
  <ul class="posts-list">
    {
      projectPosts.map((post) => (
        <OriginalBlogPost url={post.url} title={post.frontmatter.title} pubDate={post.frontmatter.updatedDate} />
      ))
    }
  </ul>
  <details>
    <summary>《C++ 代码整洁之道》读书记录</summary>
    <ul>
      {cleanCxxPosts.map((post) => <BlogPost url={post.url} title={post.frontmatter.title} />)}
    </ul>
  </details>
  <h2>搬运</h2>
  <details>
    <summary>『 设计模式 』</summary>
    <p class="source">
      Article reprinted from <a href="https://refactoring.guru/design-patterns" class="underline">Refactoring.Guru</a>
    </p>
    <details class="pattern-group">
      <summary>Creational Patterns</summary>
      <ul>
        {cxxCreationalPatternsPosts.map((post) => <BlogPost url={post.url} title={post.frontmatter.title} />)}
      </ul>
    </details>
    <details class="pattern-group">
      <summary>Structural Patterns</summary>
      <ul>
        {cxxStructuralPatternsPosts.map((post) => <BlogPost url={post.url} title={post.frontmatter.title} />)}
      </ul>
    </details>
    <details class="pattern-group">
      <summary>Behavioral Patterns</summary>
      <ul>
        {cxxBehavioralPatternsPosts.map((post) => <BlogPost url={post.url} title={post.frontmatter.title} />)}
      </ul>
    </details>
  </details>
</BaseLayout>

<style>
  h2 {
    border-left: 3px solid var(--accent);
    padding-left: 0.6rem;
    margin-bottom: 0.75rem;
  }

  .blog-tools {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: -0.25rem 0 1.25rem;
  }

  .blog-tools a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.2rem 0.8rem;
    border: 1px solid var(--tag-border);
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--muted);
    font-size: 0.86rem;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .blog-tools a:hover,
  .blog-tools a:focus-visible,
  .blog-tools a.active {
    border-color: var(--accent);
    background: var(--code-bg);
    color: var(--accent);
  }

  ul {
    padding: 0;
    margin: 0 0 1rem;
  }

  ul li {
    list-style: none;
  }


  /* 外层 details */
  details {
    margin: 0.5rem 0 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0 0.75rem;
  }

  details[open] {
    padding-bottom: 0.5rem;
  }

  details summary {
    padding: 0.65rem 0 0.65rem 0.25rem;
    font-size: 1rem;
    font-weight: 600;
    cursor: pointer;
    user-select: none;
  }

  details summary::marker,
  details summary::-webkit-details-marker {
    color: var(--accent);
    font-size: 0.75rem;
  }

  details ul {
    margin: 0.25rem 0;
    padding: 0;
  }

  /* 嵌套 pattern-group */
  details.pattern-group {
    margin: 0.4rem 0 0;
    border: none;
    border-left: 2px solid var(--border);
    border-radius: 0;
    padding: 0 0 0 0.75rem;
    background: none;
  }

  details.pattern-group[open] {
    padding-bottom: 0;
  }

  details.pattern-group > summary {
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.35rem 0;
  }

  details.pattern-group > summary::marker,
  details.pattern-group > summary::-webkit-details-marker {
    color: var(--muted);
    font-size: 0.6rem;
  }

  details.pattern-group:last-child {
    margin-bottom: 0.25rem;
  }

  .source {
    margin: 0.25rem 0 0.5rem;
    padding: 0;
    font-size: 0.8rem;
    color: var(--muted);
  }
</style>
