---
import BaseLayout from '../layouts/Base.astro'
import '../styles/roadmap.css'
import { withBase } from '../utils/path'

const pageTitle = '路'
const knowledgeElementPosts = Object.values(import.meta.glob('../content/roadmap/knowledge_element/*.md', { eager: true })) as any[]
const scatteredPosts = Object.values(import.meta.glob('../content/roadmap/scattered/*.md', { eager: true })) as any[]
---

<BaseLayout pageTitle={pageTitle}>
  <img src={withBase('/images/bird.jpg')} alt="moon" id="bird" />
  <blockquote>
    <p>虽说是工作，但我想找到乐趣</p>
  </blockquote>
  <h2>知识元</h2>
  <p>实际开发会常用到的一些知识点（不限语言）</p>
  <div id="knowledge-element">
    {
      knowledgeElementPosts.map((post) => (
        <details>
          <summary>{post.frontmatter.title}</summary>
          <div class="post-content">
            <post.Content />
          </div>
        </details>
      ))
    }
  </div>
  <p>无法说常存于大脑肌肉记忆中的（GPT生成）</p>
  <div id="scattered">
    {
      scatteredPosts.map((post) => (
        <details>
          <summary>{post.frontmatter.title}</summary>
          <div class="post-content">
            <post.Content />
          </div>
        </details>
      ))
    }
  </div>
</BaseLayout>

<script>
  if (!(window as any).__roadmapDetailsReady) {
    ;(window as any).__roadmapDetailsReady = true
    document.addEventListener(
      'toggle',
      (event) => {
        const details = event.target instanceof HTMLDetailsElement ? event.target : null
        if (!details?.open || !details.matches('#knowledge-element details, #scattered details')) return

        document.querySelectorAll<HTMLDetailsElement>('#knowledge-element details, #scattered details').forEach((otherDetails) => {
          if (otherDetails !== details) otherDetails.removeAttribute('open')
        })
      },
      true,
    )
  }
</script>
