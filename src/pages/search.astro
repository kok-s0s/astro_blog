---
import BaseLayout from '../layouts/Base.astro'
import { withBase } from '../utils/path'

const pageTitle = '搜索'
---

<BaseLayout pageTitle={pageTitle} description="全站文章搜索">
  <p class="tip">全文搜索 · 覆盖所有博文</p>
  <div id="search"></div>
</BaseLayout>

<link href={withBase('/pagefind/pagefind-ui.css')} rel="stylesheet" />
<script>
  const pagefindBase = import.meta.env.BASE_URL.replace(/\/$/, '')

  function loadPagefindUI() {
    if ((window as any).PagefindUI) return Promise.resolve()
    if ((window as any).__pagefindUILoading) return (window as any).__pagefindUILoading

    ;(window as any).__pagefindUILoading = new Promise<void>((resolve, reject) => {
      const script = document.createElement('script')
      script.src = `${pagefindBase}/pagefind/pagefind-ui.js`
      script.onload = () => resolve()
      script.onerror = () => reject(new Error('Failed to load Pagefind UI'))
      document.head.appendChild(script)
    })

    return (window as any).__pagefindUILoading
  }

  async function initSearch() {
    const el = document.getElementById('search')
    if (!el || el.dataset.ready === 'true') return
    await loadPagefindUI()
    if (!(window as any).PagefindUI) return

    el.dataset.ready = 'true'
    new (window as any).PagefindUI({
      element: '#search',
      showSubResults: true,
      showImages: false,
      translations: {
        placeholder: '输入关键词...',
        zero_results: '没有找到「[SEARCH_TERM]」相关内容',
      },
    })
  }

  document.addEventListener('astro:page-load', initSearch)
  initSearch()
</script>

<style>
  .tip {
    font-size: 0.9rem;
    color: var(--muted);
    margin-bottom: 1.5rem;
  }

  /* 一护暗色 */
  :root {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: #e8722a;
    --pagefind-ui-text: #c8b8a2;
    --pagefind-ui-background: #0e0b0a;
    --pagefind-ui-border: #3a2e26;
    --pagefind-ui-tag: #1c1612;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: 'LXGW WenKai Screen', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  /* 露琪亚亮色 */
  html.light {
    --pagefind-ui-primary: #6c3fb5;
    --pagefind-ui-text: #3d2b5e;
    --pagefind-ui-background: #faf6ff;
    --pagefind-ui-border: #c5b8e0;
    --pagefind-ui-tag: #ede8f5;
  }
</style>
