---
import BaseLayout from '../../layouts/Base.astro'

const projectPosts = Object.values(import.meta.glob('../posts/*.md', { eager: true })) as any[]
const cleanCxxPosts = Object.values(import.meta.glob('../posts/clean_cxx/*.md', { eager: true })) as any[]
const cxxCreationalPatternsPosts = Object.values(import.meta.glob('../posts/cxx_design_patterns/creational_patterns/*.md', { eager: true })) as any[]
const cxxStructuralPatternsPosts = Object.values(import.meta.glob('../posts/cxx_design_patterns/structural_patterns/*.md', { eager: true })) as any[]
const cxxBehavioralPatternsPosts = Object.values(import.meta.glob('../posts/cxx_design_patterns/behavioral_patterns/*.md', { eager: true })) as any[]
const projectTags = [...new Set(projectPosts.map((post) => post.frontmatter.tags).flat())]
const cleanCxxTags = [...new Set(cleanCxxPosts.map((post) => post.frontmatter.tags).flat())]
const cxxCreationalPatternsTags = [...new Set(cxxCreationalPatternsPosts.map((post) => post.frontmatter.tags).flat())]
const cxxStructuralPatternsTags = [...new Set(cxxStructuralPatternsPosts.map((post) => post.frontmatter.tags).flat())]
const cxxBehavioralPatternsTags = [...new Set(cxxBehavioralPatternsPosts.map((post) => post.frontmatter.tags).flat())]
const uniqueTags = [
  ...new Set([
    ...projectTags,
    ...cleanCxxTags,
    ...cxxCreationalPatternsTags,
    ...cxxStructuralPatternsTags,
    ...cxxBehavioralPatternsTags,
  ]),
]
const pageTitle = '标签'
---

<BaseLayout pageTitle={pageTitle}>
  <div class="tags">
    {
      uniqueTags.map((tag) => (
        <a href={`/tags/${tag}`} class="tag">{tag}</a>
      ))
    }
  </div>
</BaseLayout>

<style>
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.3rem 0.85rem;
    border: 1px solid var(--tag-border);
    border-radius: 999px;
    background: var(--tag-bg);
    font-size: 0.875rem;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease, transform 0.15s ease;
  }

  .tag:link,
  .tag:visited {
    color: var(--accent);
  }

  .tag:hover,
  .tag:active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
    transform: translateY(-2px);
  }
</style>
