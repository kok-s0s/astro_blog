---
import BaseLayout from '../../layouts/Base.astro'
import BlogPost from '../../components/BlogPost.astro'
import { withBase } from '../../utils/path'

export async function getStaticPaths() {
  const projectPosts = Object.values(import.meta.glob('../posts/*.md', { eager: true })) as any[]
  const cleanCxxPosts = Object.values(import.meta.glob('../posts/clean_cxx/*.md', { eager: true })) as any[]
  const cxxCreationalPatternsPosts = Object.values(import.meta.glob('../posts/cxx_design_patterns/creational_patterns/*.md', { eager: true })) as any[]
  const cxxStructuralPatternsPosts = Object.values(import.meta.glob('../posts/cxx_design_patterns/structural_patterns/*.md', { eager: true })) as any[]
  const cxxBehavioralPatternsPosts = Object.values(import.meta.glob('../posts/cxx_design_patterns/behavioral_patterns/*.md', { eager: true })) as any[]
  const projectTags = [...new Set(projectPosts.map((post) => post.frontmatter.tags).flat())]
  const cleanCxxTags = [...new Set(cleanCxxPosts.map((post) => post.frontmatter.tags).flat())]
  const cxxCreationalPatternsTags = [...new Set(cxxCreationalPatternsPosts.map((post) => post.frontmatter.tags).flat())]
  const cxxStructuralPatternsTags = [...new Set(cxxStructuralPatternsPosts.map((post) => post.frontmatter.tags).flat())]
  const cxxBehavioralPatternsTags = [...new Set(cxxBehavioralPatternsPosts.map((post) => post.frontmatter.tags).flat())]
  const uniqueTags = [
    ...new Set([
      ...projectTags,
      ...cleanCxxTags,
      ...cxxCreationalPatternsTags,
      ...cxxStructuralPatternsTags,
      ...cxxBehavioralPatternsTags,
    ]),
  ]
  const allPosts = projectPosts
    .concat(cleanCxxPosts)
    .concat(cxxCreationalPatternsPosts)
    .concat(cxxStructuralPatternsPosts)
    .concat(cxxBehavioralPatternsPosts)

  return uniqueTags.map((tag) => {
    const filteredPosts = allPosts.filter((post) => post.frontmatter.tags.includes(tag))
    return {
      params: { tag },
      props: { posts: filteredPosts },
    }
  })
}

const { tag } = Astro.params
const { posts } = Astro.props
---

<BaseLayout pageTitle={tag}>
  <p class="subtitle">{posts.length} 篇文章带有此标签</p>
  <nav class="tag-nav" aria-label="标签浏览方式">
    <a href={withBase('/tags')}>全部标签</a>
    <a href={withBase('/blog')}>文章</a>
    <a href={withBase('/archive')}>归档</a>
  </nav>
  <ul>
    {posts.map((post) => <BlogPost url={post.url} title={post.frontmatter.title} />)}
  </ul>
</BaseLayout>

<style>
  .subtitle {
    margin: 0 0 0.75rem;
    font-size: 0.9rem;
    color: var(--muted);
  }

  .tag-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 0 0 1.25rem;
  }

  .tag-nav a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.2rem 0.8rem;
    border: 1px solid var(--tag-border);
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--muted);
    font-size: 0.86rem;
    transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .tag-nav a:hover,
  .tag-nav a:focus-visible {
    border-color: var(--accent);
    background: var(--code-bg);
    color: var(--accent);
  }

  ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
</style>
