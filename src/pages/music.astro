---
import BaseLayout from '../layouts/Base.astro'

const UID = '467185512'

type Track = {
  id: number
  name: string
  artists: string[]
  album: string
  cover: string
  duration: number
}

let tracks: Track[] = []
let fetchError = ''

const HEADERS = {
  'User-Agent':
    'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36',
  Referer: 'https://music.163.com/',
}

function formatDuration(ms: number): string {
  const s = Math.floor(ms / 1000)
  const m = Math.floor(s / 60)
  return `${m}:${(s % 60).toString().padStart(2, '0')}`
}

function coverUrl(url: string): string {
  const clean = url.replace(/^https?:\/\//, '')
  return `https://wsrv.nl/?url=${clean}&w=120&output=webp`
}

function songUrl(id: number): string {
  return `https://music.163.com/#/song?id=${id}`
}

try {
  const plRes = await fetch(
    `https://music.163.com/api/user/playlist?uid=${UID}&limit=1&offset=0`,
    { headers: HEADERS }
  )
  const plData = await plRes.json()
  const playlistId: number = plData.playlist?.[0]?.id
  if (!playlistId) throw new Error('无法获取歌单 ID')

  const detailRes = await fetch(
    `https://music.163.com/api/v3/playlist/detail?id=${playlistId}&n=500`,
    { headers: HEADERS }
  )
  const detailData = await detailRes.json()
  const trackIds: number[] = (detailData.playlist?.trackIds ?? []).map((t: any) => t.id)
  if (trackIds.length === 0) throw new Error('歌单为空')

  const idsStr = '[' + trackIds.join(',') + ']'
  const songRes = await fetch('https://music.163.com/api/song/detail', {
    method: 'POST',
    headers: { ...HEADERS, 'Content-Type': 'application/x-www-form-urlencoded' },
    body: `ids=${encodeURIComponent(idsStr)}`,
  })
  const songData = await songRes.json()

  const songMap = new Map<number, any>((songData.songs ?? []).map((s: any) => [s.id, s]))

  tracks = trackIds
    .map((id) => {
      const s = songMap.get(id)
      if (!s) return null
      return {
        id: s.id,
        name: s.name,
        artists: (s.artists ?? []).map((a: any) => a.name),
        album: s.album?.name ?? '',
        cover: s.album?.picUrl ?? '',
        duration: s.duration ?? 0,
      } satisfies Track
    })
    .filter(Boolean) as Track[]
} catch (e: any) {
  fetchError = e.message ?? '获取音乐列表失败'
}

const tracksForClient = tracks.map((t) => ({
  id: t.id,
  name: t.name,
  artists: t.artists,
  cover: coverUrl(t.cover),
}))
---

<BaseLayout pageTitle="音乐" description="kok-s0s 喜欢的音乐">
  <p class="count-line">
    共收藏 <strong>{tracks.length}</strong> 首 · 来自
    <a
      href={`https://music.163.com/#/user/home?id=${UID}`}
      target="_blank"
      rel="noopener"
      class="ncm-link">网易云音乐</a
    >
  </p>

  {
    fetchError ? (
      <p class="fetch-error">获取失败：{fetchError}</p>
    ) : (
      <ul class="track-list" id="track-list">
        {tracks.map((track, i) => (
          <li>
            <a
              href={songUrl(track.id)}
              target="_blank"
              rel="noopener"
              class="track-row"
              data-index={i}
            >
              <span class="track-index">
                <span class="idx-num">{i + 1}</span>
                <span class="idx-bars" aria-hidden="true">
                  <i /><i /><i />
                </span>
              </span>
              <div class="cover-wrap">
                <img
                  src={coverUrl(track.cover)}
                  alt={track.album}
                  loading="lazy"
                  data-no-zoom
                />
              </div>
              <div class="track-info">
                <span class="track-name">{track.name}</span>
                <span class="track-sub">{track.artists.join(' / ')}</span>
              </div>
              <span class="track-album">{track.album}</span>
              <span class="track-duration">{formatDuration(track.duration)}</span>
            </a>
          </li>
        ))}
      </ul>
    )
  }

  <!-- ── 播放器 ── -->
  <div id="player" class="player" hidden>
    <div class="pl-left">
      <img id="pl-cover" class="pl-cover" src="" alt="" data-no-zoom />
      <div class="pl-meta">
        <span id="pl-name" class="pl-name"></span>
        <span id="pl-artist" class="pl-artist"></span>
      </div>
    </div>

    <div class="pl-center">
      <div class="pl-btns">
        <button class="pl-btn" id="btn-prev" title="上一首">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
            <rect x="2" y="3" width="2.5" height="12" rx="1"/>
            <path d="M5.5 9 15 3v12L5.5 9z"/>
          </svg>
        </button>
        <button class="pl-btn pl-play-btn" id="btn-play" title="播放">
          <svg class="icon-play" width="22" height="22" viewBox="0 0 22 22" fill="currentColor">
            <path d="M5 3.5l14 7.5-14 7.5V3.5z"/>
          </svg>
          <svg class="icon-pause" width="22" height="22" viewBox="0 0 22 22" fill="currentColor" style="display:none">
            <rect x="4" y="3" width="5" height="16" rx="1.5"/>
            <rect x="13" y="3" width="5" height="16" rx="1.5"/>
          </svg>
        </button>
        <button class="pl-btn" id="btn-next" title="下一首">
          <svg width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
            <rect x="13.5" y="3" width="2.5" height="12" rx="1"/>
            <path d="M12.5 9 3 3v12l9.5-6z"/>
          </svg>
        </button>
      </div>
      <div class="pl-progress-row">
        <span class="pl-time" id="time-cur">0:00</span>
        <input type="range" id="pl-progress" class="pl-range" min="0" max="1000" value="0" step="1" />
        <span class="pl-time" id="time-tot">0:00</span>
      </div>
    </div>

    <div class="pl-right">
      <button class="pl-btn pl-vol-btn" id="btn-mute" title="静音">
        <svg class="icon-vol" width="18" height="18" viewBox="0 0 18 18" fill="currentColor">
          <path d="M2 6.5v5h3.5L10 15V3L5.5 6.5H2zm11 2.5a3 3 0 0 0-1.5-2.6v5.2A3 3 0 0 0 13 9zm2.5 0a5.5 5.5 0 0 0-4-5.3v1.6A4 4 0 0 1 14 9a4 4 0 0 1-2.5 3.7v1.6A5.5 5.5 0 0 0 15.5 9z"/>
        </svg>
        <svg class="icon-mute" width="18" height="18" viewBox="0 0 18 18" fill="currentColor" style="display:none">
          <path d="M2 6.5v5h3.5L10 15V3L5.5 6.5H2z"/>
          <path d="m13 7-1 1 1.5 1.5L12 11l1 1 1.5-1.5L16 12l1-1-1.5-1.5L17 8l-1-1-1.5 1.5L13 7z"/>
        </svg>
      </button>
      <input type="range" id="pl-volume" class="pl-range pl-vol-range" min="0" max="100" value="80" step="1" />
    </div>
  </div>

  <audio id="ncm-audio" preload="none"></audio>
  <script type="application/json" id="ncm-tracks" is:inline set:html={JSON.stringify(tracksForClient)} />
</BaseLayout>

<style>
  .count-line {
    font-size: 0.85rem;
    color: var(--muted);
    margin: 0 0 1.25rem;
  }
  .count-line strong { color: var(--accent); }
  .ncm-link { color: var(--accent) !important; }

  .fetch-error {
    color: var(--muted);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem;
    text-align: center;
  }

  /* ── 曲目列表 ── */
  .track-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .track-list li + li {
    border-top: 1px solid var(--border);
  }

  .track-row {
    display: grid;
    grid-template-columns: 2rem 3rem 1fr auto auto;
    align-items: center;
    gap: 0.75rem;
    padding: 0.45rem 0.5rem;
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.15s;
    color: inherit;
  }
  .track-row:hover {
    background: var(--code-bg);
  }

  /* 序号 / 播放条 */
  .track-index {
    position: relative;
    width: 2rem;
    height: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }
  .idx-num {
    font-size: 0.8rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    transition: opacity 0.15s;
  }
  .idx-bars {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    gap: 2px;
    opacity: 0;
    transition: opacity 0.15s;
  }
  .idx-bars i {
    display: block;
    width: 3px;
    border-radius: 1px;
    background: var(--accent);
    height: 40%;
    animation: bar-bounce 0.8s ease-in-out infinite alternate;
  }
  .idx-bars i:nth-child(2) { animation-delay: 0.2s; }
  .idx-bars i:nth-child(3) { animation-delay: 0.4s; }

  @keyframes bar-bounce {
    from { height: 30%; }
    to   { height: 90%; }
  }

  .track-row.is-playing .idx-num { opacity: 0; }
  .track-row.is-playing .idx-bars { opacity: 1; }
  .track-row.is-playing .track-name { color: var(--accent); }

  /* 封面 */
  .cover-wrap {
    width: 3rem;
    height: 3rem;
    border-radius: 4px;
    overflow: hidden;
    background: var(--code-bg);
    flex-shrink: 0;
  }
  .cover-wrap img {
    display: block;
    width: 3rem;
    height: 3rem;
    object-fit: cover;
  }

  /* 信息 */
  .track-info {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }
  .track-name {
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--heading);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.15s;
  }
  .track-row:hover .track-name { color: var(--accent); }
  .track-sub {
    font-size: 0.78rem;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .track-album {
    font-size: 0.8rem;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 10rem;
  }

  .track-duration {
    font-size: 0.8rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  /* ── 播放器 ── */
  .player {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    height: 64px;
    background: var(--toc-bg);
    border-top: 1px solid var(--border);
    box-shadow: 0 -4px 16px rgba(0,0,0,0.25);
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0 1rem;
    z-index: 200;
  }
  .player[hidden] { display: none; }

  .pl-left {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    min-width: 0;
    width: 220px;
    flex-shrink: 0;
  }
  .pl-cover {
    width: 44px;
    height: 44px;
    border-radius: 4px;
    object-fit: cover;
    flex-shrink: 0;
  }
  .pl-meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
    gap: 0.1rem;
  }
  .pl-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--heading);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .pl-artist {
    font-size: 0.75rem;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .pl-center {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
    min-width: 0;
  }
  .pl-btns {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }
  .pl-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--muted);
    padding: 0.35rem;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.15s, background 0.15s;
    line-height: 0;
  }
  .pl-btn:hover { color: var(--heading); background: var(--code-bg); }
  .pl-play-btn {
    width: 38px;
    height: 38px;
    background: var(--accent) !important;
    color: #fff !important;
  }
  .pl-play-btn:hover { background: var(--accent-hover) !important; }

  .pl-progress-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    width: 100%;
  }
  .pl-time {
    font-size: 0.72rem;
    color: var(--muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* range 公共样式 */
  .pl-range {
    -webkit-appearance: none;
    appearance: none;
    height: 3px;
    border-radius: 999px;
    background: var(--border);
    outline: none;
    cursor: pointer;
    flex: 1;
  }
  .pl-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--accent);
    cursor: pointer;
    transition: transform 0.1s;
  }
  .pl-range::-webkit-slider-thumb:hover { transform: scale(1.3); }
  .pl-range::-moz-range-thumb {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--accent);
    border: none;
    cursor: pointer;
  }

  .pl-right {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    width: 140px;
    flex-shrink: 0;
  }
  .pl-vol-range { flex: 1; }

  /* ── 响应式 ── */
  @media (max-width: 600px) {
    .track-row {
      grid-template-columns: 2rem 2.75rem 1fr auto;
    }
    .track-album { display: none; }

    .player {
      height: auto;
      flex-direction: column;
      gap: 0.4rem;
      padding: 0.6rem 0.75rem 0.5rem;
    }
    .pl-left { width: 100%; }
    .pl-center { width: 100%; }
    .pl-right { display: none; }
    .pl-btns { gap: 0.5rem; }
  }

  @media (max-width: 400px) {
    .track-row {
      grid-template-columns: 2.75rem 1fr auto;
    }
    .track-index { display: none; }
  }
</style>

<style is:global>
  body:has(#player:not([hidden])) {
    padding-bottom: 72px;
  }
  @media (max-width: 600px) {
    body:has(#player:not([hidden])) {
      padding-bottom: 110px;
    }
  }
</style>

<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    var tracks = JSON.parse(document.getElementById('ncm-tracks').textContent || '[]')
    var audio = document.getElementById('ncm-audio')
    var player = document.getElementById('player')
    var plCover = document.getElementById('pl-cover')
    var plName = document.getElementById('pl-name')
    var plArtist = document.getElementById('pl-artist')
    var btnPlay = document.getElementById('btn-play')
    var btnPrev = document.getElementById('btn-prev')
    var btnNext = document.getElementById('btn-next')
    var btnMute = document.getElementById('btn-mute')
    var progress = document.getElementById('pl-progress')
    var volume = document.getElementById('pl-volume')
    var timeCur = document.getElementById('time-cur')
    var timeTot = document.getElementById('time-tot')
    var iconPlay = btnPlay.querySelector('.icon-play')
    var iconPause = btnPlay.querySelector('.icon-pause')
    var iconVol = btnMute.querySelector('.icon-vol')
    var iconMute = btnMute.querySelector('.icon-mute')
    var rows = Array.from(document.querySelectorAll('.track-row'))

    var currentIndex = -1

    function fmt(sec) {
      var m = Math.floor(sec / 60)
      var s = Math.floor(sec % 60)
      return m + ':' + (s < 10 ? '0' : '') + s
    }

    function setPlayIcon(playing) {
      iconPlay.style.display = playing ? 'none' : ''
      iconPause.style.display = playing ? '' : 'none'
    }

    function updateProgress() {
      var dur = audio.duration || 0
      var cur = audio.currentTime || 0
      timeCur.textContent = fmt(cur)
      timeTot.textContent = dur ? fmt(dur) : '0:00'
      if (dur > 0) {
        var pct = cur / dur
        progress.value = Math.round(pct * 1000)
        progress.style.background =
          'linear-gradient(to right, var(--accent) ' + (pct * 100).toFixed(1) + '%, var(--border) ' + (pct * 100).toFixed(1) + '%)'
      }
    }

    function play(index) {
      if (index < 0 || index >= tracks.length) return
      var t = tracks[index]
      currentIndex = index

      rows.forEach(function (r, i) {
        r.classList.toggle('is-playing', i === index)
      })

      plCover.src = t.cover
      plName.textContent = t.name
      plArtist.textContent = t.artists.join(' / ')
      player.hidden = false

      // 先停当前播放，显示加载中
      audio.pause()
      audio.src = ''
      setPlayIcon(false)
      btnPlay.disabled = true

      fetch('/.netlify/functions/ncm-url?id=' + t.id)
        .then(function (res) { return res.json() })
        .then(function (data) {
          audio.src = data.url || ('https://music.163.com/song/media/outer/url?id=' + t.id)
          audio.volume = volume.value / 100
          btnPlay.disabled = false
          return audio.play()
        })
        .catch(function () {
          // 回退到公开直链（非会员歌曲仍可播）
          audio.src = 'https://music.163.com/song/media/outer/url?id=' + t.id
          audio.volume = volume.value / 100
          btnPlay.disabled = false
          audio.play().catch(function () {})
        })
    }

    audio.addEventListener('timeupdate', updateProgress)

    audio.addEventListener('play', function () { setPlayIcon(true) })
    audio.addEventListener('pause', function () { setPlayIcon(false) })
    audio.addEventListener('ended', function () {
      play((currentIndex + 1) % tracks.length)
    })

    btnPlay.addEventListener('click', function () {
      if (currentIndex < 0) { play(0); return }
      if (audio.paused) audio.play()
      else audio.pause()
    })

    btnPrev.addEventListener('click', function () {
      // 若播放超 3s 则重置当前曲，否则切上一首
      if (audio.currentTime > 3) {
        audio.currentTime = 0
      } else {
        play((currentIndex - 1 + tracks.length) % tracks.length)
      }
    })

    btnNext.addEventListener('click', function () {
      play((currentIndex + 1) % tracks.length)
    })

    btnMute.addEventListener('click', function () {
      audio.muted = !audio.muted
      iconVol.style.display = audio.muted ? 'none' : ''
      iconMute.style.display = audio.muted ? '' : 'none'
    })

    progress.addEventListener('input', function () {
      if (audio.duration) {
        audio.currentTime = (this.value / 1000) * audio.duration
      }
    })

    volume.addEventListener('input', function () {
      audio.volume = this.value / 100
      if (audio.muted) {
        audio.muted = false
        iconVol.style.display = ''
        iconMute.style.display = 'none'
      }
    })

    // 音量进度条初始填充色
    volume.style.background =
      'linear-gradient(to right, var(--accent) 80%, var(--border) 80%)'
    volume.addEventListener('input', function () {
      volume.style.background =
        'linear-gradient(to right, var(--accent) ' + this.value + '%, var(--border) ' + this.value + '%)'
    })

    // 曲目行点击 → 播放
    rows.forEach(function (row, i) {
      row.addEventListener('click', function (e) {
        e.preventDefault()
        play(i)
      })
    })
  })
</script>
